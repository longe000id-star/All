from flask import Flask, request   # 导入 request

app = Flask(__name__)

@app.before_request
def before_request_func():
    print("=== before_request 钩子执行了 ===")
    print(f"请求方法: {request.method}")
    print(f"请求路径: {request.path}")

@app.route('/')
def index():
    return "<h1>Hello, World!</h1>"

@app.route('/user/<name>')
def user(name):
    return f"<h1>Hello, {name}!</h1>"

if __name__ == '__main__':
    app.run(debug=True)